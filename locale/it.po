#: lib/bookshelf_settings.lua:3523
msgid "Choose image library folder"
msgstr "Scegli la cartella della libreria immagini"

#: lib/bookshelf_settings.lua:3549
msgid "\"Latest\" folder walk depth"
msgstr "Profondità di scansione cartella \"Recenti\""

#: lib/bookshelf_settings.lua:3550
msgid ""
"How deep to scan your library folder for newly-added books. Higher values "
"take longer on a cold start."
msgstr ""
"Quanto in profondità scansionare la cartella della libreria per libri "
"aggiunti di recente. Valori più alti rallentano l'avvio a freddo."

#: lib/bookshelf_settings.lua:3566
msgid "MB"
msgstr "MB"

#: lib/bookshelf_settings.lua:3567
msgid "Cover cache budget"
msgstr "Budget cache copertine"

#: lib/bookshelf_settings.lua:3568
msgid ""
"Memory budget for ready-scaled book covers (MB). Higher = smoother paging "
"and preloading, more RAM. Default 24 MB."
msgstr ""
"Budget di memoria per le copertine già ridimensionate (MB). Più alto = "
"impaginazione e precaricamento più fluidi, più RAM. Predefinito 24 MB."

#: lib/bookshelf_settings.lua:3702
msgid "Link copied to clipboard"
msgstr "Link copiato negli appunti"

#: lib/bookshelf_settings.lua:3778
msgid "Notify on wake when update available"
msgstr "Notifica al risveglio quando è disponibile un aggiornamento"

#: lib/bookshelf_settings.lua:3797
