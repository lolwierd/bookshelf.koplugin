#: lib/bookshelf_settings.lua:3198
msgid "Chip bar font scale"
msgstr "Escala de fuente de la barra de chips"

#: lib/bookshelf_settings.lua:3262
msgid "Stack & folder label scale"
msgstr "Escala de etiquetas de pilas y carpetas"

#: lib/bookshelf_settings.lua:3335
msgid "Start menu font scale"
msgstr "Escala de fuente del menú de inicio"

#: lib/bookshelf_settings.lua:3425
msgid "Modal tab label font scale"
msgstr "Escala de fuente de las pestañas del modal"

#: lib/bookshelf_settings.lua:3499
msgid "Hero card"
msgstr "Tarjeta destacada"

#: lib/bookshelf_settings.lua:3500
msgid "Hero micro-modules"
msgstr "Micro-módulos destacados"

#: lib/bookshelf_settings.lua:3501
msgid "Chip bar"
msgstr "Barra de chips"

#: lib/bookshelf_settings.lua:3502
msgid "Stack & folder labels"
msgstr "Etiquetas de pilas y carpetas"

#: lib/bookshelf_settings.lua:3503
msgid "Expanded shelf labels"
msgstr "Etiquetas de estantería expandida"

#: lib/bookshelf_settings.lua:3504
msgid "Cover badges"
msgstr "Insignias de portada"

#: lib/bookshelf_settings.lua:3506
msgid "Modal tabs"
msgstr "Pestañas del modal"

#: lib/bookshelf_settings.lua:3523
msgid "Choose image library folder"
msgstr "Elegir carpeta de biblioteca de imágenes"

#: lib/bookshelf_settings.lua:3549
msgid "\"Latest\" folder walk depth"
msgstr "Profundidad de búsqueda para «Recientes»"

#: lib/bookshelf_settings.lua:3550
msgid ""
"How deep to scan your library folder for newly-added books. Higher values "
"take longer on a cold start."
msgstr ""
"Cuánto explorar tu carpeta de biblioteca para encontrar libros recién "
"añadidos. Los valores más altos tardan más al arrancar en frío."

#: lib/bookshelf_settings.lua:3566
msgid "MB"
msgstr "MB"

#: lib/bookshelf_settings.lua:3567
msgid "Cover cache budget"
msgstr "Presupuesto de caché de portadas"

#: lib/bookshelf_settings.lua:3568
msgid ""
"Memory budget for ready-scaled book covers (MB). Higher = smoother paging "
"and preloading, more RAM. Default 24 MB."
msgstr ""
"Presupuesto de memoria para las portadas de libros ya escaladas (MB). Mayor "
"= paginación y precarga más fluidas, más RAM. Predeterminado 24 MB."

#: lib/bookshelf_settings.lua:3702
msgid "Link copied to clipboard"
msgstr "Enlace copiado al portapapeles"

#: lib/bookshelf_settings.lua:3778
msgid "Notify on wake when update available"
msgstr "Notificar al despertar si hay actualización"

#: lib/bookshelf_settings.lua:3797
msgid "Update available"
msgstr "Actualización disponible"

#: lib/bookshelf_settings.lua:3800
msgid "Installed version"
msgstr "Versión instalada"

#: lib/bookshelf_settings.lua:3806
msgid "Developer updates"
msgstr "Actualizaciones de desarrollador"

#: lib/bookshelf_settings.lua:3811 lib/bookshelf_settings.lua:3812
#: main.lua:1770
msgid "Development branch"
msgstr "Branch de desarrollo"

#: lib/bookshelf_settings.lua:3822
msgid "Check for updates"
msgstr "Buscar actualizaciones"

#: lib/bookshelf_settings.lua:3823
msgid "Install branch"
msgstr "Instalar branch"

#: lib/bookshelf_settings.lua:3829
msgid "Reset to latest stable release"
msgstr "Restablecer a la última versión estable"

#: lib/bookshelf_settings.lua:3840 lib/bookshelf_settings.lua:3843
msgid "Installed: v"
msgstr "Instalado: v"

#: lib/bookshelf_settings.lua:3883
msgid "Flexible chip widths"
msgstr "Anchos de chip flexibles"

#: lib/bookshelf_settings.lua:3884
msgid ""
"Off: every chip gets the same width. On: each chip is sized to its label, so "
"single-icon chips stay narrow and longer text labels get more room. Falls "
"back to equal widths when natural sizes don't fit."
msgstr ""
"Desactivado: todos los chips tienen el mismo ancho. Activado: cada chip se "
"ajusta al tamaño de su etiqueta, de modo que los chips de un solo icono "
"quedan estrechos y las etiquetas más largas disponen de más espacio. Se "
"vuelve al ancho uniforme cuando los tamaños naturales no caben."

#: lib/bookshelf_settings.lua:3944
msgid "+ Add new chip"
msgstr "+ Añadir chip"

#: lib/bookshelf_sort_engine.lua:351
msgid "Filename"
msgstr "Nombre de archivo"

#: lib/bookshelf_sort_engine.lua:355
msgid "Author (given name)"
msgstr "Autor (nombre de pila)"

#: lib/bookshelf_sort_engine.lua:357
msgid "Author surname"
msgstr "Apellido del autor"

#: lib/bookshelf_sort_engine.lua:359 lib/bookshelf_tokens.lua:64
msgid "Series name"
msgstr "Nombre de serie"

#: lib/bookshelf_sort_engine.lua:363
msgid "Series #"
msgstr "Nº de serie"

#: lib/bookshelf_sort_engine.lua:363
msgid "Series index"
msgstr "Índice de serie"

#: lib/bookshelf_sort_engine.lua:371
msgid "Series + #"
msgstr "Series + nº"

#: lib/bookshelf_sort_engine.lua:371
msgid "Series + index"
msgstr "Series + índice"

#: lib/bookshelf_sort_engine.lua:381
msgid "Last opened"
msgstr "Última apertura"

#: lib/bookshelf_sort_engine.lua:381
msgid "Opened"
msgstr "Abierto"

#: lib/bookshelf_sort_engine.lua:387 lib/bookshelf_tokens.lua:77
msgid "Percent read"
msgstr "Porcentaje leído"

